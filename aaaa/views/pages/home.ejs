<% layout("layouts/boilerplate") %>

<!-- ═══════ HERO SECTION ═══════ -->
<section class="relative overflow-hidden pt-24 pb-16 lg:pt-32 lg:pb-24 bg-slate-50">
  <!-- Dynamic Background Patterns -->
  <div class="absolute inset-0 z-0 opacity-40">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-secondary/10 rounded-full blur-[100px] translate-y-1/4 -translate-x-1/4"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div data-aos="fade-right">
        <div class="inline-flex items-center gap-2 bg-secondary/20 text-secondary-dark px-4 py-2 rounded-full font-bold text-xs uppercase tracking-wider mb-6 border border-secondary/30">
          <i class="fas fa-certificate animate-pulse"></i> Authorized Bikaji Distributor
        </div>
        <h1 class="text-5xl lg:text-6xl font-black text-dark leading-[1.1] mb-6 tracking-tight">
          Quality You Can <span class="text-primary italic">Taste</span>, <br />
          Service You Can <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">Trust</span>.
        </h1>
        <p class="text-lg text-gray-600 mb-10 max-w-xl leading-relaxed">
          Geeta Traders brings the authentic flavors of Bikaji directly to your doorstep. From crispy Bhujia to delicious Sweets, we ensure fresh stock and wholesale prices for every partner.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="/products" class="px-8 py-4 bg-primary text-white rounded-2xl font-bold text-lg shadow-2xl shadow-primary/30 hover:scale-105 transition-all flex items-center justify-center gap-3 group">
            Explore Catalog <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
          </a>
          <a href="/inquiry" class="px-8 py-4 bg-white text-dark border-2 border-gray-100 rounded-2xl font-bold text-lg hover:bg-gray-50 transition-all flex items-center justify-center gap-3">
            Bulk Order Inquiry
          </a>
        </div>
        <div class="flex flex-wrap gap-8">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-md text-primary"><i class="fas fa-truck"></i></div>
            <span class="font-bold text-dark text-sm">24h Delivery</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-md text-primary"><i class="fas fa-check"></i></div>
            <span class="font-bold text-dark text-sm">Fresh Stock</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-md text-primary"><i class="fas fa-tag"></i></div>
            <span class="font-bold text-dark text-sm">Wholesale Rates</span>
          </div>
        </div>
      </div>

      <div class="relative" data-aos="zoom-in" data-aos-delay="200">
        <div class="absolute -inset-4 bg-gradient-to-tr from-primary/20 to-accent/20 rounded-[40px] blur-2xl z-0 animate-pulse"></div>
        <div class="relative z-10 bg-white p-4 rounded-[40px] shadow-2xl overflow-hidden border border-gray-100">
          <img src="https://images.unsplash.com/photo-1601050690597-df0568f70950?q=80&w=1200&auto=format&fit=crop" alt="Bikaji Snacks" class="w-full h-full object-cover rounded-[32px] hover:scale-105 transition-transform duration-700" />
          <!-- Floating UI elements -->
          <div class="absolute bottom-10 left-10 right-10 bg-white/90 backdrop-blur-md p-6 rounded-2xl border border-white/50 shadow-xl" data-aos="fade-up" data-aos-delay="500">
            <div class="flex items-center gap-4">
              <div class="flex -space-x-3">
                <img src="https://i.pravatar.cc/100?u=1" class="w-10 h-10 rounded-full border-2 border-white" />
                <img src="https://i.pravatar.cc/100?u=2" class="w-10 h-10 rounded-full border-2 border-white" />
                <img src="https://i.pravatar.cc/100?u=3" class="w-10 h-10 rounded-full border-2 border-white" />
              </div>
              <div>
                <p class="text-xs font-bold text-dark">Joined by 500+ Retailers</p>
                <p class="text-[10px] text-gray-500 font-medium">Daily fresh deliveries across the city</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════ TRUST METRICS ═══════ -->
<section class="py-12 bg-white border-b border-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 text-center">
      <div data-aos="fade-up">
        <div class="text-5xl font-black text-dark mb-2 tracking-tighter">15<span class="text-primary">+</span></div>
        <p class="text-gray-500 font-bold uppercase tracking-widest text-xs">Years of Trust</p>
      </div>
      <div data-aos="fade-up" data-aos-delay="100">
        <div class="text-5xl font-black text-dark mb-2 tracking-tighter">500<span class="text-primary">+</span></div>
        <p class="text-gray-500 font-bold uppercase tracking-widest text-xs">Retail Partners</p>
      </div>
      <div data-aos="fade-up" data-aos-delay="200">
        <div class="text-5xl font-black text-dark mb-2 tracking-tighter">24<span class="text-primary">h</span></div>
        <p class="text-gray-500 font-bold uppercase tracking-widest text-xs">Express Delivery</p>
      </div>
      <div data-aos="fade-up" data-aos-delay="300">
        <div class="text-5xl font-black text-dark mb-2 tracking-tighter">100<span class="text-primary">%</span></div>
        <p class="text-gray-500 font-bold uppercase tracking-widest text-xs">Authenticity</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════ FEATURED PRODUCTS ═══════ -->
<section class="py-16 bg-slate-50 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6">
      <div data-aos="fade-right">
        <span class="text-primary font-black uppercase tracking-[3px] text-sm mb-4 block">Our Best Sellers</span>
        <h2 class="text-4xl lg:text-5xl font-black text-dark tracking-tight">Featured Products</h2>
      </div>
      <a href="/products" class="text-dark font-bold hover:text-primary transition-colors flex items-center gap-2 group" data-aos="fade-left">
        View Complete Catalog <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
      </a>
    </div>

    <% if (featuredProducts && featuredProducts.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <% featuredProducts.forEach((product, i) => { %>
          <div class="group bg-white p-4 rounded-premium border border-gray-100 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2" data-aos="fade-up" data-aos-delay="<%= i * 100 %>">
            <div class="relative h-64 bg-slate-50 rounded-[20px] overflow-hidden mb-6 flex items-center justify-center">
              <img src="<%= product.image %>" alt="<%= product.name %>" class="max-h-full object-contain p-6 group-hover:scale-110 transition-transform duration-500" />
              <div class="absolute top-4 left-4 px-3 py-1 bg-white/90 backdrop-blur-md rounded-full text-[10px] font-bold text-primary uppercase border border-gray-100 shadow-sm"><%= product.category %></div>
            </div>
            <div class="px-2">
              <h3 class="text-xl font-bold text-dark mb-2 line-clamp-1 group-hover:text-primary transition-colors"><%= product.name %></h3>
              <p class="text-xs text-gray-500 font-medium mb-6 flex items-center gap-2">
                <i class="fas fa-box text-primary"></i> <%= product.packSizes.join(" | ") %>
              </p>
              <div class="flex gap-2">
                <a href="/products/<%= product.slug %>" class="flex-1 py-3 bg-slate-50 text-dark rounded-xl font-bold text-xs hover:bg-dark hover:text-white transition-all text-center">Details</a>
                <a href="/inquiry?product=<%= product._id %>" class="flex-[1.5] py-3 bg-primary text-white rounded-xl font-bold text-xs hover:bg-dark transition-all text-center">Enquire</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<!-- ═══════ CATEGORIES GRID ═══════ -->
<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-primary font-black uppercase tracking-[3px] text-sm mb-4 block" data-aos="fade-up">Diverse Range</span>
      <h2 class="text-4xl lg:text-5xl font-black text-dark tracking-tight mb-6" data-aos="fade-up" data-aos-delay="100">Browse by Category</h2>
      <p class="text-gray-500 font-medium" data-aos="fade-up" data-aos-delay="200">From spicy namkeens to melt-in-the-mouth sweets, we have it all.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6">
      <% const catIcons = { 'Namkeen': 'seedling', 'Sweets': 'candy-cane', 'Snacks': 'cookie-bite', 'Gift Packs': 'gift', 'Papad': 'circle' }; %>
      <% ['Namkeen', 'Sweets', 'Snacks', 'Gift Packs', 'Papad'].forEach((cat, i) => { %>
        <a href="/products?category=<%= cat %>" class="group p-8 bg-slate-50 rounded-premium border border-transparent hover:border-primary hover:bg-white hover:shadow-2xl transition-all duration-500 text-center" data-aos="zoom-in" data-aos-delay="<%= i * 100 %>">
          <div class="w-16 h-16 mx-auto bg-white rounded-2xl flex items-center justify-center text-3xl text-primary shadow-lg group-hover:bg-primary group-hover:text-white group-hover:rotate-12 transition-all mb-6">
            <i class="fas fa-<%= catIcons[cat] %>"></i>
          </div>
          <h3 class="text-xl font-black text-dark mb-2"><%= cat %></h3>
          <p class="text-xs text-gray-400 font-medium mb-4">View All Items</p>
          <span class="inline-block px-3 py-1 bg-primary/10 text-primary text-[10px] font-black rounded-full uppercase tracking-widest"><%= categoryCounts[cat] || 0 %> Products</span>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- ═══════ CTA SECTION ═══════ -->
<section class="py-16 relative overflow-hidden">
  <div class="absolute inset-0 bg-dark z-0">
     <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
  </div>
  <div class="max-w-5xl mx-auto px-6 relative z-10 text-center">
    <div class="bg-gradient-to-br from-primary to-accent p-12 lg:p-20 rounded-[40px] shadow-2xl relative overflow-hidden" data-aos="flip-up">
      <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
      <h2 class="text-4xl lg:text-6xl font-black text-white mb-8 leading-tight tracking-tight relative z-10">
        Ready to Grow Your <br class="hidden lg:block" /> Business with <span class="text-secondary">Bikaji?</span>
      </h2>
      <p class="text-xl text-white/80 mb-12 max-w-2xl mx-auto font-medium relative z-10">
        Join our network of 500+ successful retailers. Get the best wholesale prices, fresh stock, and reliable support.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center relative z-10">
        <a href="/inquiry" class="px-10 py-5 bg-white text-primary rounded-2xl font-black text-lg hover:scale-105 transition-all shadow-xl">
          Start Bulk Inquiry
        </a>
        <a href="https://wa.me/<%= whatsappNumber %>" class="px-10 py-5 bg-dark text-white rounded-2xl font-black text-lg border border-white/20 hover:bg-white hover:text-dark transition-all flex items-center justify-center gap-3">
          <i class="fab fa-whatsapp text-2xl text-[#25D366]"></i> Message Us on WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>
