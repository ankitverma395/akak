<% layout("layouts/boilerplate") %>

<!-- ═══════ HERO SECTION ═══════ -->
<section class="relative overflow-hidden pt-24 pb-16 lg:pt-32 lg:pb-24 bg-slate-50">

  <!-- Background -->
  <div class="absolute inset-0 z-0 opacity-40">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-secondary/10 rounded-full blur-[100px] translate-y-1/4 -translate-x-1/4"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">

    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- LEFT CONTENT -->
      <div data-aos="fade-right">

        <div class="inline-flex items-center gap-2 bg-secondary/20 text-secondary-dark px-4 py-2 rounded-full font-bold text-xs uppercase tracking-wider mb-6 border border-secondary/30">
          <i class="fas fa-certificate animate-pulse"></i> Authorized Bikaji Distributor
        </div>

        <h1 class="text-5xl lg:text-6xl font-black text-dark leading-[1.1] mb-6 tracking-tight">
          Quality You Can <span class="text-primary italic">Taste</span>, <br />
          Service You Can <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">Trust</span>.
        </h1>

        <p class="text-lg text-gray-600 mb-10 max-w-xl leading-relaxed">
          Geeta Traders brings the authentic flavors of Bikaji directly to your doorstep. From crispy Bhujia to delicious Sweets, we ensure fresh stock and wholesale prices for every partner.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="/products" class="px-8 py-4 bg-primary text-white rounded-2xl font-bold text-lg shadow-2xl shadow-primary/30 hover:scale-105 transition-all flex items-center justify-center gap-3 group">
            Explore Catalog <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
          </a>

          <a href="/inquiry" class="px-8 py-4 bg-white text-dark border-2 border-gray-100 rounded-2xl font-bold text-lg hover:bg-gray-50 transition-all flex items-center justify-center gap-3">
            Bulk Order Inquiry
          </a>
        </div>

      </div>

      <!-- RIGHT IMAGE SECTION -->
      <div class="relative" data-aos="zoom-in" data-aos-delay="200">

        <div class="absolute -inset-4 bg-gradient-to-tr from-primary/20 to-accent/20 rounded-[40px] blur-2xl z-0 animate-pulse"></div>

        <div class="relative z-10 bg-white p-4 rounded-[40px] shadow-2xl overflow-hidden border border-gray-100">

          <!-- MAIN IMAGE -->
          <img src="/images/bikaji-bhujia.jpg"
               alt="Bikaji Bhujia"
               class="w-full h-full object-cover rounded-[32px] hover:scale-105 transition-transform duration-700" />

          <!-- Floating UI -->
          <div class="absolute bottom-10 left-10 right-10 bg-white/90 backdrop-blur-md p-6 rounded-2xl border border-white/50 shadow-xl"
               data-aos="fade-up" data-aos-delay="500">

            <div class="flex items-center gap-4">

              <div class="flex -space-x-3">
                <img src="https://i.pravatar.cc/100?u=1" class="w-10 h-10 rounded-full border-2 border-white" />
                <img src="https://i.pravatar.cc/100?u=2" class="w-10 h-10 rounded-full border-2 border-white" />
                <img src="https://i.pravatar.cc/100?u=3" class="w-10 h-10 rounded-full border-2 border-white" />
              </div>

              <div>
                <p class="text-xs font-bold text-dark">Joined by 500+ Retailers</p>
                <p class="text-[10px] text-gray-500 font-medium">
                  Daily fresh deliveries across the city
                </p>
              </div>

            </div>

          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<!-- ✅ EXTRA IMAGE (ADDED AS REQUESTED, NO OTHER CHANGE) -->
<div class="max-w-7xl mx-auto px-6 mt-10">
  <img src="/images/bikaji-bhujia.jpg"
       alt="Bikaji Bhujia"
       class="w-full object-cover rounded-[32px] hover:scale-105 transition-transform duration-700" />
</div>
