<% layout("layouts/boilerplate") %>

<!-- ═══════ PAGE HERO ═══════ -->
<section class="relative pt-24 pb-12 bg-dark overflow-hidden">
  <div class="absolute inset-0 opacity-20 bg-[url('https://www.transparenttextures.com/patterns/grid.png')]"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
    <div class="inline-flex items-center gap-2 bg-primary/20 text-primary px-4 py-2 rounded-full font-bold text-xs uppercase tracking-widest mb-6 border border-primary/30" data-aos="fade-down">
      Wholesale & Retail
    </div>
    <h1 class="text-5xl lg:text-7xl font-black text-white tracking-tight mb-6" data-aos="fade-up">
      Bulk <span class="text-primary italic">Inquiry</span>
    </h1>
    <div class="flex items-center justify-center gap-3 text-gray-400 font-bold text-sm" data-aos="fade-up" data-aos-delay="200">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <i class="fas fa-chevron-right text-[10px] opacity-50"></i>
      <span class="text-primary">Inquiry</span>
    </div>
  </div>
</section>

<!-- ═══════ INQUIRY GRID ═══════ -->
<section class="py-16 bg-slate-50 relative">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-3 gap-12">
      <!-- Inquiry Form -->
      <div class="lg:col-span-2" data-aos="fade-right">
        <div class="bg-white p-10 lg:p-16 rounded-[40px] shadow-2xl shadow-dark/5 border border-gray-100 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
          
          <h2 class="text-3xl lg:text-4xl font-black text-dark tracking-tight mb-8">Tell Us What You <span class="text-primary italic">Need</span></h2>
          
          <form action="/inquiry" method="POST" class="space-y-8">
            <div class="grid md:grid-cols-2 gap-8">
              <div class="space-y-2">
                <label class="text-xs font-black text-gray-400 uppercase tracking-widest ml-1">Full Name *</label>
                <input type="text" name="name" required placeholder="John Doe" class="w-full px-6 py-4 bg-slate-50 border border-gray-100 rounded-2xl focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-bold" />
              </div>
              <div class="space-y-2">
                <label class="text-xs font-black text-gray-400 uppercase tracking-widest ml-1">Phone Number *</label>
                <input type="tel" name="phone" required placeholder="+91 XXXXX XXXXX" class="w-full px-6 py-4 bg-slate-50 border border-gray-100 rounded-2xl focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-bold" />
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
              <div class="space-y-2">
                <label class="text-xs font-black text-gray-400 uppercase tracking-widest ml-1">Business Name</label>
                <input type="text" name="shopName" placeholder="Your Shop Name" class="w-full px-6 py-4 bg-slate-50 border border-gray-100 rounded-2xl focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-bold" />
              </div>
              <div class="space-y-2">
                <label class="text-xs font-black text-gray-400 uppercase tracking-widest ml-1">Inquiry Type</label>
                <select name="inquiryType" class="w-full px-6 py-4 bg-slate-50 border border-gray-100 rounded-2xl focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-bold appearance-none">
                  <option value="bulk">Bulk / Wholesale</option>
                  <option value="retail">Retail Store</option>
                  <option value="general">General Question</option>
                </select>
              </div>
            </div>
            
            <div class="space-y-2">
              <label class="text-xs font-black text-gray-400 uppercase tracking-widest ml-1">Location / City</label>
              <input type="text" name="location" placeholder="e.g. Bikaner, Rajasthan" class="w-full px-6 py-4 bg-slate-50 border border-gray-100 rounded-2xl focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-bold" />
            </div>
            
            <div class="space-y-2">
              <label class="text-xs font-black text-gray-400 uppercase tracking-widest ml-1">Your Requirements *</label>
              <textarea name="productRequirement" required rows="5" placeholder="Please list the products and quantities you need..." class="w-full px-6 py-4 bg-slate-50 border border-gray-100 rounded-2xl focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-bold resize-none"></textarea>
            </div>
            
            <% if (productId) { %>
              <input type="hidden" name="productId" value="<%= productId %>" />
            <% } %>

            <button type="submit" class="w-full py-5 bg-primary text-white rounded-2xl font-black text-xl hover:bg-dark hover:shadow-2xl hover:shadow-primary/30 transition-all flex items-center justify-center gap-4 group">
              Submit Inquiry <i class="fas fa-paper-plane group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"></i>
            </button>
          </form>
        </div>
      </div>

      <!-- Inquiry Info -->
      <div class="space-y-8" data-aos="fade-left">
        <div class="bg-dark p-10 rounded-[40px] text-white shadow-2xl relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-primary/20 rounded-full blur-2xl"></div>
          <h3 class="text-2xl font-black tracking-tight mb-6">Need Instant Quote?</h3>
          <p class="text-gray-400 font-medium mb-8">Chat with our distribution team on WhatsApp for immediate pricing and availability.</p>
          <a href="https://wa.me/<%= whatsappNumber %>" class="w-full py-4 bg-[#25D366] text-white rounded-2xl font-black flex items-center justify-center gap-3 hover:scale-105 transition-all">
            <i class="fab fa-whatsapp text-2xl"></i> Chat with Us
          </a>
        </div>

        <div class="bg-white p-10 rounded-[40px] border border-gray-100 shadow-xl">
          <h3 class="text-2xl font-black text-dark tracking-tight mb-8 flex items-center gap-3">
             <i class="fas fa-info-circle text-primary"></i> How it Works
          </h3>
          <div class="space-y-8 relative">
            <div class="absolute left-4 top-2 bottom-2 w-0.5 bg-slate-100"></div>
            <div class="relative pl-12">
               <div class="absolute left-0 top-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center text-xs font-black">1</div>
               <h4 class="font-bold text-dark text-sm mb-1">Fill Inquiry</h4>
               <p class="text-[11px] text-gray-400 font-medium leading-relaxed">Tell us what you need and where you are located.</p>
            </div>
            <div class="relative pl-12">
               <div class="absolute left-0 top-0 w-8 h-8 bg-slate-100 text-gray-400 rounded-full flex items-center justify-center text-xs font-black">2</div>
               <h4 class="font-bold text-dark text-sm mb-1">Stock Review</h4>
               <p class="text-[11px] text-gray-400 font-medium leading-relaxed">Our team checks for the freshest stock in our warehouse.</p>
            </div>
            <div class="relative pl-12">
               <div class="absolute left-0 top-0 w-8 h-8 bg-slate-100 text-gray-400 rounded-full flex items-center justify-center text-xs font-black">3</div>
               <h4 class="font-bold text-dark text-sm mb-1">Best Quote</h4>
               <p class="text-[11px] text-gray-400 font-medium leading-relaxed">You receive a personalized quote via call or message.</p>
            </div>
            <div class="relative pl-12">
               <div class="absolute left-0 top-0 w-8 h-8 bg-slate-100 text-gray-400 rounded-full flex items-center justify-center text-xs font-black">4</div>
               <h4 class="font-bold text-dark text-sm mb-1">Fast Delivery</h4>
               <p class="text-[11px] text-gray-400 font-medium leading-relaxed">Once confirmed, your order is dispatched within 24 hours.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
