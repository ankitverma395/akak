<% layout("layouts/adminBoilerplate") %>

<div class="max-w-4xl">
  <div class="bg-white rounded-premium shadow-2xl shadow-dark/5 border border-gray-100 overflow-hidden">
    <div class="bg-dark p-6 text-white flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-black tracking-tight">Edit Product</h2>
        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mt-1">Modifying: <%= product.name %></p>
      </div>
      <i class="fas fa-edit text-4xl opacity-20"></i>
    </div>
    
    <div class="p-6">
      <form action="/admin/products/<%= product._id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="space-y-8">
        <div class="grid md:grid-cols-2 gap-8">
          <div class="space-y-2">
            <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Product Name *</label>
            <input type="text" name="name" required value="<%= product.name %>" class="w-full px-4 py-3 bg-slate-50 border border-gray-100 rounded-2xl focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-bold" />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Category *</label>
            <select name="category" required class="w-full px-4 py-3 bg-slate-50 border border-gray-100 rounded-2xl focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-bold appearance-none bg-[url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2224%22 height=%2224%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23D11218%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22%3E%3Cpolyline points=%226 9 12 15 18 9%22%3E%3C/polyline%3E%3C/svg%3E')] bg-no-repeat bg-[right_1.5rem_center] bg-[length:1rem]">
              <% ['Namkeen','Sweets','Snacks','Gift Packs','Papad','Beverages','Other'].forEach(cat => { %>
                <option value="<%= cat %>" <%= product.category === cat ? 'selected' : '' %>><%= cat %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Product Description</label>
          <textarea name="description" rows="4" class="w-full px-4 py-3 bg-slate-50 border border-gray-100 rounded-2xl focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-bold resize-none"><%= product.description %></textarea>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="space-y-2">
            <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Pack Sizes (comma separated)</label>
            <input type="text" name="packSizes" value="<%= product.packSizes.join(', ') %>" class="w-full px-4 py-3 bg-slate-50 border border-gray-100 rounded-2xl focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-bold" />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Display Sort Order</label>
            <input type="number" name="sortOrder" value="<%= product.sortOrder %>" class="w-full px-4 py-3 bg-slate-50 border border-gray-100 rounded-2xl focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-bold" />
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-end">
          <div class="space-y-2">
             <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Current Image</label>
             <div class="w-full h-48 bg-slate-50 rounded-2xl border border-gray-100 p-4 flex items-center justify-center">
                <img src="<%= product.image %>" class="max-h-full object-contain" />
             </div>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Replace Image (Optional)</label>
            <div class="relative group h-48">
               <input type="file" name="image" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
               <div class="w-full h-full bg-slate-50 border-2 border-dashed border-gray-200 rounded-2xl flex flex-col items-center justify-center gap-4 group-hover:border-primary transition-colors">
                  <i class="fas fa-cloud-upload-alt text-3xl text-gray-300 group-hover:text-primary transition-colors"></i>
                  <p class="font-bold text-dark text-xs text-center px-4">Drag new image here or click</p>
               </div>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-8 bg-slate-50 p-6 rounded-2xl border border-gray-100">
           <label class="flex items-center gap-3 cursor-pointer group">
              <input type="checkbox" name="featured" <%= product.featured ? 'checked' : '' %> class="w-5 h-5 rounded border-gray-300 text-primary focus:ring-primary" />
              <span class="font-bold text-dark text-sm group-hover:text-primary transition-colors">Featured Product</span>
           </label>
           <label class="flex items-center gap-3 cursor-pointer group">
              <input type="checkbox" name="available" <%= product.available ? 'checked' : '' %> class="w-5 h-5 rounded border-gray-300 text-green-500 focus:ring-green-500" />
              <span class="font-bold text-dark text-sm group-hover:text-green-600 transition-colors">Mark as Available</span>
           </label>
        </div>

        <div class="flex gap-4 pt-6">
          <button type="submit" class="flex-1 py-5 bg-primary text-white rounded-2xl font-black text-xl shadow-xl shadow-primary/20 hover:bg-dark transition-all flex items-center justify-center gap-3 group">
            <i class="fas fa-save group-hover:scale-110 transition-transform"></i> Update Changes
          </button>
          <a href="/admin/products" class="px-8 py-5 bg-slate-100 text-slate-500 rounded-2xl font-black text-xl hover:bg-slate-200 transition-all">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
