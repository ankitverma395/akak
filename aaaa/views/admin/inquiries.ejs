<% layout("layouts/adminBoilerplate") %>

<div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
  <div class="flex items-center gap-4 overflow-x-auto pb-2 md:pb-0 no-scrollbar">
    <% const statuses = ['new', 'contacted', 'in-progress', 'completed', 'cancelled']; %>
    <a href="/admin/inquiries" class="px-6 py-2 rounded-full font-bold text-xs uppercase tracking-widest transition-all 
      <%= !selectedStatus ? 'bg-primary text-white shadow-lg shadow-primary/20' : 'bg-white text-gray-400 border border-gray-100 hover:border-primary hover:text-primary' %>">
      All Leads
    </a>
    <% statuses.forEach(s => { %>
      <a href="/admin/inquiries?status=<%= s %>" class="px-6 py-2 rounded-full font-bold text-xs uppercase tracking-widest transition-all 
        <%= selectedStatus === s ? 'bg-primary text-white shadow-lg shadow-primary/20' : 'bg-white text-gray-400 border border-gray-100 hover:border-primary hover:text-primary' %>">
        <%= s.replace('-', ' ') %>
      </a>
    <% }) %>
  </div>
</div>

<div class="bg-white rounded-premium border border-gray-100 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 text-[10px] font-black text-gray-400 uppercase tracking-widest">
          <th class="px-6 py-3">Partner / Contact</th>
          <th class="px-6 py-3">Requirement Details</th>
          <th class="px-6 py-3">Type</th>
          <th class="px-6 py-3">Status</th>
          <th class="px-6 py-3 text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% inquiries.forEach(inq => { %>
          <tr class="hover:bg-slate-50/50 transition-colors group">
            <td class="px-6 py-4">
              <div class="font-black text-dark text-lg leading-tight mb-1"><%= inq.name %></div>
              <div class="flex flex-col gap-1">
                 <a href="tel:<%= inq.phone %>" class="text-xs font-bold text-primary hover:underline flex items-center gap-2">
                   <i class="fas fa-phone-alt text-[10px]"></i> <%= inq.phone %>
                 </a>
                 <div class="text-[10px] text-gray-400 font-bold uppercase tracking-widest flex items-center gap-2">
                   <i class="fas fa-store"></i> <%= inq.shopName || 'Individual' %>
                 </div>
              </div>
            </td>
            <td class="px-6 py-4 max-w-md">
              <div class="text-sm font-bold text-gray-600 mb-2">
                <%= inq.product ? inq.product.name : inq.productRequirement %>
              </div>
              <div class="flex items-center gap-3">
                 <span class="text-[10px] font-bold text-gray-400 bg-gray-50 px-2 py-0.5 rounded border border-gray-100">Qty: <%= inq.quantity || 'N/A' %></span>
                 <span class="text-[10px] font-bold text-gray-400 bg-gray-50 px-2 py-0.5 rounded border border-gray-100"><%= inq.createdAt.toLocaleDateString() %></span>
              </div>
            </td>
            <td class="px-6 py-4">
              <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-full text-[10px] font-black uppercase tracking-widest">
                <%= inq.inquiryType %>
              </span>
            </td>
            <td class="px-6 py-4">
              <form action="/admin/inquiries/<%= inq._id %>?_method=PUT" method="POST">
                <select name="status" onchange="this.form.submit()" class="px-3 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest cursor-pointer border-2 transition-all
                  <%= inq.status === 'new' ? 'border-orange-200 bg-orange-50 text-orange-600 focus:border-orange-500' : 
                      inq.status === 'completed' ? 'border-green-200 bg-green-50 text-green-600 focus:border-green-500' :
                      inq.status === 'cancelled' ? 'border-red-200 bg-red-50 text-red-600 focus:border-red-500' :
                      'border-blue-200 bg-blue-50 text-blue-600 focus:border-blue-500' %>">
                  <% statuses.forEach(s => { %>
                    <option value="<%= s %>" <%= inq.status === s ? 'selected' : '' %>><%= s.replace('-', ' ') %></option>
                  <% }) %>
                </select>
              </form>
            </td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                <a href="https://wa.me/<%= inq.phone.replace(/[^0-9]/g,'') %>" target="_blank" class="w-10 h-10 bg-green-50 text-green-600 rounded-xl flex items-center justify-center hover:bg-green-600 hover:text-white transition-all shadow-sm">
                  <i class="fab fa-whatsapp"></i>
                </a>
                <form action="/admin/inquiries/<%= inq._id %>?_method=DELETE" method="POST" class="inline" onsubmit="return confirm('Archive this inquiry?')">
                  <button class="w-10 h-10 bg-red-50 text-red-600 rounded-xl flex items-center justify-center hover:bg-red-600 hover:text-white transition-all shadow-sm">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (inquiries.length === 0) { %>
    <div class="p-20 text-center">
      <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center text-gray-300 text-3xl mx-auto mb-6">
        <i class="fas fa-envelope-open"></i>
      </div>
      <h3 class="text-xl font-black text-dark mb-2">No Inquiries Found</h3>
      <p class="text-gray-400 font-medium">All caught up! No leads in this category.</p>
    </div>
  <% } %>
</div>
